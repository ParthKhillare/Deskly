modules = ["nodejs-20"]
run = "npm run dev"

[nix]
channel = "stable-23_11"

[[hints]]
# This hint tells Replit to use the webview for port 3000
port = 3000
path = "/"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vite --port=5000 --host=0.0.0.0"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "dist"
